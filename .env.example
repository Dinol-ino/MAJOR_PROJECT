# DFrag Environment Configurations Template
# Copy this file to .env and configure as needed

# URL where local Ollama is running
OLLAMA_URL=http://localhost:11434

# Default 3B model for legal assistant
DEFAULT_MODEL=qwen2.5:3b

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_db

# Cryptographic Audit log database path
SQLITE_DB_PATH=./audit_log.db
