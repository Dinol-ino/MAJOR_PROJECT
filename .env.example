# DFrag Environment Configurations Template
# Copy this file to .env and configure as needed.

# Current model runtime
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=qwen2.5:3b

# Legacy persistence kept during the staged cutover
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_DB_PATH=./audit_log.db
CHROMA_LEGACY_ENABLED=true

# Stage 1 platform foundation
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dfrag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://postgres:replace-me@localhost:5432/dfrag
PGVECTOR_DIMENSIONS=1024
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=7200

# Stage 2 ingestion and PageIndex
UPLOAD_ROOT=./data/uploads
DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
MAX_FILE_SIZE_MB=10
MAX_FILE_PAGES=100
OCR_ENABLED=false
OCR_LANGUAGE=en
OCR_MIN_TEXT_THRESHOLD=0.15

# Optional Stage 2 OCR runtime
# Install PaddleOCR and platform OCR dependencies only if OCR_ENABLED=true.
# PADDLEOCR_HOME=

# Future retrieval models
# EMBEDDING_MODEL=jinaai/jina-embeddings-v3
# EMBEDDING_DIMENSIONS=1024
# RERANKER_MODEL=BAAI/bge-reranker-large
# INJECTION_MODEL=nlpaueb/legal-bert-base-uncased
# NLI_MODEL=

# Future generation runtime
# MODEL_RUNTIME=ollama
# GENERATOR_MODEL=google/gemma-3-4b-it
# GENERATOR_CONTEXT_TOKENS=131072
# HF_TOKEN=

# Future observability
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
